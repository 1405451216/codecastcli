# LLM Provider: openai | anthropic | gemini | deepseek | qwen | glm | ollama
LLM_PROVIDER=openai

# API Key
LLM_API_KEY=your-api-key-here

# Model (optional, defaults shown)
# LLM_MODEL=gpt-4o
# LLM_MODEL=claude-3-sonnet-20240229
# LLM_MODEL=deepseek-chat

# Custom API Base URL (optional)
# LLM_BASE_URL=https://custom-api.example.com/v1

# ===== 语义索引配置（v1.0+，可选）=====
# 启用后对代码库做 embedding + BM25 混合检索
# SEMANTIC_INDEX_ENABLED=false

# Embedding Provider: openai | zhipu | dashscope | mock
# - openai:    text-embedding-3-small（1536 维，海外）
# - zhipu:     智谱 embedding-3（2048 维，国内推荐）
# - dashscope: 通义 text-embedding-v3（1024 维，阿里云）
# - mock:      测试用，无网络依赖
# SEMANTIC_INDEX_EMBEDDING_PROVIDER=zhipu

# Embedding 专用 API Key（为空则复用 LLM_API_KEY）
# 用智谱/通义时建议单独填，因为它们的 key 与主 LLM provider 可能不同
# SEMANTIC_INDEX_EMBEDDING_API_KEY=your-zhipu-or-dashscope-key

# Embedding 专用 Base URL（为空则用 provider 默认值）
# SEMANTIC_INDEX_EMBEDDING_BASE_URL=

# Embedding 模型名
# SEMANTIC_INDEX_EMBEDDING_MODEL=embedding-3

# 单个 chunk 最大行数
# SEMANTIC_INDEX_MAX_CHUNK_LINES=100

# ===== 学习型路由配置（v1.0+，可选）=====
# 启用后根据历史成功率自适应选择模型
# LEARNING_ROUTING_ENABLED=false
# LEARNING_ROUTING_EPSILON=0.1
# LEARNING_ROUTING_MIN_SAMPLES=10
