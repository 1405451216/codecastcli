# 强制源码/文档使用 LF，Windows 用户本地 checkout 不会引入 CRLF。
# 已存在 CRLF 的文件需要先 `git rm --cached` 再 re-add，或用 dos2unix 一次性转换。
* text=auto eol=lf

# 显式声明文本类（避免误判为 binary）
*.go      text eol=lf
*.py      text eol=lf
*.md      text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.sh      text eol=lf
*.bash    text eol=lf
*.zsh     text eol=lf
*.fish    text eol=lf
*.ps1     text eol=lf

# Windows 资源/批处理保留 CRLF
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.psm1    text eol=crlf

# 二进制
*.exe     binary
*.png     binary
*.jpg     binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.tar.gz  binary
